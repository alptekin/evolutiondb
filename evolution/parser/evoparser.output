  508              | GLOBAL TEMPORARY

  509 create_col_list: create_definition
  510                | create_col_list ',' create_definition

  511 create_definition: PRIMARY KEY '(' pk_column_list ')'
  512                  | CONSTRAINT NAME PRIMARY KEY '(' pk_column_list ')'
  513                  | KEY '(' column_list ')'
  514                  | INDEX '(' column_list ')'
  515                  | FULLTEXT INDEX '(' column_list ')'
  516                  | FULLTEXT KEY '(' column_list ')'
  517                  | CHECK '(' expr ')'
  518                  | CONSTRAINT NAME CHECK '(' expr ')'
  519                  | FOREIGN KEY '(' fk_column_list ')' REFERENCES NAME '(' fk_ref_column_list ')' fk_actions
  520                  | FOREIGN KEY '(' fk_column_list ')' REFERENCES NAME '.' NAME '(' fk_ref_column_list ')' fk_actions
  521                  | CONSTRAINT NAME FOREIGN KEY '(' fk_column_list ')' REFERENCES NAME '(' fk_ref_column_list ')' fk_actions
  522                  | CONSTRAINT NAME FOREIGN KEY '(' fk_column_list ')' REFERENCES NAME '.' NAME '(' fk_ref_column_list ')' fk_actions
  523                  | UNIQUE '(' unique_column_list ')'
  524                  | CONSTRAINT NAME UNIQUE '(' unique_column_list ')'

  525 pk_column_list: NAME
  526               | pk_column_list ',' NAME

  527 fk_column_list: NAME
  528               | fk_column_list ',' NAME

  529 fk_ref_column_list: NAME
  530                   | fk_ref_column_list ',' NAME

  531 fk_actions: /* empty */
  532           | fk_actions ON DELETE CASCADE
  533           | fk_actions ON DELETE SET NULLX
  534           | fk_actions ON DELETE RESTRICT
  535           | fk_actions ON DELETE SET DEFAULT
  536           | fk_actions ON UPDATE CASCADE
  537           | fk_actions ON UPDATE SET NULLX
  538           | fk_actions ON UPDATE RESTRICT
  539           | fk_actions ON UPDATE SET DEFAULT
  540           | fk_actions ON DELETE NO_ACTION
  541           | fk_actions ON UPDATE NO_ACTION
  542           | fk_actions MATCH FULL
  543           | fk_actions MATCH SIMPLE
  544           | fk_actions MATCH PARTIAL
  545           | fk_actions DEFERRABLE
  546           | fk_actions NOT DEFERRABLE
  547           | fk_actions DEFERRABLE INITIALLY DEFERRED
  548           | fk_actions DEFERRABLE INITIALLY IMMEDIATE

  549 unique_column_list: NAME
  550                   | unique_column_list ',' NAME

  551 @33: /* empty */

  552 create_definition: @33 NAME data_type column_atts

  553 column_atts: /* empty */
  554            | column_atts NOT NULLX
  555            | column_atts NULLX
  556            | column_atts DEFAULT STRING
  557            | column_atts DEFAULT INTNUM
  558            | column_atts DEFAULT APPROXNUM
  559            | column_atts DEFAULT BOOL
  560            | column_atts DEFAULT FGEN_RANDOM_UUID '(' ')'
  561            | column_atts DEFAULT FGEN_RANDOM_UUID_V7 '(' ')'
  562            | column_atts DEFAULT FSNOWFLAKE_ID '(' ')'
  563            | column_atts DEFAULT CURRENT_TIMESTAMP
  564            | column_atts DEFAULT '(' expr ')'
  565            | column_atts AUTO_INCREMENT
  566            | column_atts AUTO_INCREMENT '(' INTNUM ',' INTNUM ')'
  567            | column_atts AUTO_INCREMENT '(' INTNUM ')'
  568            | column_atts IDENTITY '(' INTNUM ',' INTNUM ')'
  569            | column_atts IDENTITY '(' INTNUM ')'
  570            | column_atts IDENTITY
  571            | column_atts UNIQUE KEY
  572            | column_atts UNIQUE
  573            | column_atts PRIMARY KEY
  574            | column_atts KEY
  575            | column_atts COMMENT STRING
  576            | column_atts CHECK '(' expr ')'
  577            | column_atts CONSTRAINT NAME UNIQUE
  578            | column_atts CONSTRAINT NAME PRIMARY KEY
  579            | column_atts CONSTRAINT NAME CHECK '(' expr ')'
  580            | column_atts GENERATED ALWAYS AS '(' expr ')' STORED
  581            | column_atts GENERATED ALWAYS AS '(' expr ')' VIRTUAL
  582            | column_atts GENERATED ALWAYS AS '(' expr ')'
  583            | column_atts AS '(' expr ')' STORED
  584            | column_atts AS '(' expr ')' VIRTUAL
  585            | column_atts AS '(' expr ')'

  586 opt_length: /* empty */
  587           | '(' INTNUM ')'
  588           | '(' INTNUM ',' INTNUM ')'

  589 opt_binary: /* empty */
  590           | BINARY

  591 opt_uz: /* empty */
  592       | opt_uz UNSIGNED
  593       | opt_uz ZEROFILL

  594 opt_csc: /* empty */
  595        | opt_csc CHAR SET STRING
  596        | opt_csc COLLATE STRING

  597 data_type: BIT opt_length
  598          | TINYINT opt_length opt_uz
  599          | SMALLINT opt_length opt_uz
  600          | MEDIUMINT opt_length opt_uz
  601          | INT opt_length opt_uz
  602          | INTEGER opt_length opt_uz
  603          | BIGINT opt_length opt_uz
  604          | REAL opt_length opt_uz
  605          | DOUBLE opt_length opt_uz
  606          | FLOAT opt_length opt_uz
  607          | DECIMAL opt_length opt_uz
  608          | DATE
  609          | TIME
  610          | TIMESTAMP
  611          | DATETIME
  612          | YEAR
  613          | CHAR opt_length opt_csc
  614          | VARCHAR '(' INTNUM ')' opt_csc
  615          | BINARY opt_length
  616          | VARBINARY '(' INTNUM ')'
  617          | TINYBLOB
  618          | BLOB
  619          | MEDIUMBLOB
  620          | LONGBLOB
  621          | TINYTEXT opt_binary opt_csc
  622          | TEXT opt_binary opt_csc
  623          | MEDIUMTEXT opt_binary opt_csc
  624          | LONGTEXT opt_binary opt_csc
  625          | ENUM '(' enum_list ')' opt_csc
  626          | SET '(' enum_list ')' opt_csc
  627          | BOOLEAN
  628          | UUID
  629          | JSON

  630 enum_list: STRING
  631          | enum_list ',' STRING

  632 create_select_statement: opt_ignore_replace opt_as select_stmt

  633 opt_ignore_replace: /* empty */
  634                   | IGNORE
  635                   | REPLACE

  636 stmt: set_stmt

  637 set_stmt: SET SCHEMA NAME
  638         | SET SCHEMA DEFAULT
  639         | SET set_list

  640 set_list: set_expr
  641         | set_list ',' set_expr

  642 set_expr: USERVAR COMPARISON expr
  643         | USERVAR ASSIGN expr

  644 stmt: create_procedure_stmt

  645 create_procedure_stmt: CREATE PROCEDURE NAME '(' opt_proc_params ')' AS BEGINWORK proc_body_skip END
  646                      | CREATE PROCEDURE NAME '(' opt_proc_params ')' BEGINWORK proc_body_skip END
  647                      | CREATE OR REPLACE PROCEDURE NAME '(' opt_proc_params ')' AS BEGINWORK proc_body_skip END
  648                      | CREATE OR REPLACE PROCEDURE NAME '(' opt_proc_params ')' BEGINWORK proc_body_skip END
  649                      | CREATE FUNCTION NAME '(' opt_proc_params ')' RETURNS proc_return_type AS BEGINWORK proc_body_skip END
  650                      | CREATE FUNCTION NAME '(' opt_proc_params ')' RETURNS proc_return_type BEGINWORK proc_body_skip END
  651                      | CREATE OR REPLACE FUNCTION NAME '(' opt_proc_params ')' RETURNS proc_return_type AS BEGINWORK proc_body_skip END
  652                      | CREATE OR REPLACE FUNCTION NAME '(' opt_proc_params ')' RETURNS proc_return_type BEGINWORK proc_body_skip END

  653 opt_proc_params: /* empty */
  654                | proc_param_list

  655 proc_param_list: proc_param
  656                | proc_param_list ',' proc_param

  657 proc_param: NAME data_type
  658           | IN NAME data_type
  659           | OUT NAME data_type
  660           | INOUT NAME data_type

  661 proc_return_type: INTEGER
  662                 | INT
  663                 | VARCHAR
  664                 | TEXT
  665                 | BOOLEAN
  666                 | FLOAT
  667                 | DOUBLE
  668                 | BIGINT
  669                 | DATE
  670                 | TIMESTAMP

  671 proc_body_skip: /* empty */
  672               | proc_body_skip proc_body_any
  673               | proc_body_skip BEGINWORK proc_body_skip END
  674               | proc_body_skip IF proc_body_skip END IF
  675               | proc_body_skip WHILE proc_body_skip END WHILE
  676               | proc_body_skip LOOP proc_body_skip END LOOP
  677               | proc_body_skip FOREACH proc_body_skip END FOREACH
  678               | proc_body_skip CASE proc_body_skip END CASE

