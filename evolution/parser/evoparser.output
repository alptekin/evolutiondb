state 1

  377 alter_table_stmt: ALTER . TABLE NAME ADD CONSTRAINT NAME CHECK '(' expr ')'
  378                 | ALTER . TABLE NAME ADD CONSTRAINT NAME UNIQUE '(' unique_column_list ')'
  379                 | ALTER . TABLE NAME ADD CONSTRAINT NAME FOREIGN KEY '(' fk_column_list ')' REFERENCES NAME '(' fk_ref_column_list ')' fk_actions
  380                 | ALTER . TABLE NAME ADD CONSTRAINT NAME CHECK '(' expr ')' NOT VALIDATE
  381                 | ALTER . TABLE NAME ADD CONSTRAINT NAME FOREIGN KEY '(' fk_column_list ')' REFERENCES NAME '(' fk_ref_column_list ')' fk_actions NOT VALIDATE
  382                 | ALTER . TABLE NAME ADD CONSTRAINT NAME PRIMARY KEY '(' pk_column_list ')'
  383                 | ALTER . TABLE NAME DROP CONSTRAINT NAME
  384                 | ALTER . TABLE NAME RENAME CONSTRAINT NAME TO NAME
  385                 | ALTER . TABLE NAME ENABLE CONSTRAINT NAME
