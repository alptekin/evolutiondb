  742 stmt: drop_procedure_stmt

  743 drop_procedure_stmt: DROP PROCEDURE NAME
  744                    | DROP PROCEDURE IF EXISTS NAME
  745                    | DROP FUNCTION NAME
  746                    | DROP FUNCTION IF EXISTS NAME

  747 stmt: call_stmt

  748 call_stmt: CALL NAME '(' ')'
  749          | CALL NAME '(' call_arg_list ')'

  750 call_arg_list: call_arg
  751              | call_arg_list ',' call_arg

  752 call_arg: INTNUM
  753         | STRING
