  832 stmt: drop_procedure_stmt

  833 drop_procedure_stmt: DROP PROCEDURE NAME
  834                    | DROP PROCEDURE IF EXISTS NAME
  835                    | DROP FUNCTION NAME
  836                    | DROP FUNCTION IF EXISTS NAME

  837 stmt: call_stmt

  838 call_stmt: CALL NAME '(' ')'
  839          | CALL NAME '(' call_arg_list ')'

  840 call_arg_list: call_arg
  841              | call_arg_list ',' call_arg

  842 call_arg: INTNUM
  843         | STRING
  844         | APPROXNUM
  845         | NULLX
  846         | BOOL
  847         | NAME
  848         | USERVAR

  849 stmt: create_trigger_stmt

  850 create_trigger_stmt: CREATE TRIGGER NAME trigger_timing trigger_event ON NAME FOR EACH ROW BEGINWORK proc_body_skip END

  851 trigger_timing: BEFORE
  852               | AFTER

  853 trigger_event: INSERT
  854              | UPDATE
  855              | DELETE

  856 stmt: drop_trigger_stmt

  857 drop_trigger_stmt: DROP TRIGGER NAME
  858                  | DROP TRIGGER IF EXISTS NAME

  859 stmt: ALTER TRIGGER NAME ENABLE
  860     | ALTER TRIGGER NAME DISABLE
  861     | create_sequence_stmt

  862 create_sequence_stmt: CREATE SEQUENCE opt_if_not_exists NAME seq_options

  863 seq_options: /* empty */
  864            | seq_options seq_option

  865 seq_option: START WITH INTNUM
  866           | START INTNUM
  867           | INCREMENT BY INTNUM
  868           | INCREMENT INTNUM
  869           | MINVALUE INTNUM
  870           | MAXVALUE INTNUM
  871           | CYCLE
