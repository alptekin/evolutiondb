  849     | ALTER SEQUENCE NAME RENAME TO NAME

  850 opt_returning: /* empty */
  851              | RETURNING '*'
  852              | RETURNING returning_col_list

  853 returning_col_list: NAME
  854                   | returning_col_list ',' NAME


