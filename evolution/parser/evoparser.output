  500            | column_atts DEFAULT CURRENT_TIMESTAMP
  501            | column_atts DEFAULT '(' expr ')'
  502            | column_atts AUTO_INCREMENT
  503            | column_atts AUTO_INCREMENT '(' INTNUM ',' INTNUM ')'
  504            | column_atts AUTO_INCREMENT '(' INTNUM ')'
  505            | column_atts IDENTITY '(' INTNUM ',' INTNUM ')'
  506            | column_atts IDENTITY '(' INTNUM ')'
  507            | column_atts IDENTITY
  508            | column_atts UNIQUE KEY
  509            | column_atts UNIQUE
  510            | column_atts PRIMARY KEY
  511            | column_atts KEY
  512            | column_atts COMMENT STRING
  513            | column_atts CHECK '(' expr ')'
  514            | column_atts CONSTRAINT NAME UNIQUE
  515            | column_atts CONSTRAINT NAME PRIMARY KEY
  516            | column_atts CONSTRAINT NAME CHECK '(' expr ')'
  517            | column_atts GENERATED ALWAYS AS '(' expr ')' STORED
  518            | column_atts GENERATED ALWAYS AS '(' expr ')' VIRTUAL
  519            | column_atts GENERATED ALWAYS AS '(' expr ')'
  520            | column_atts AS '(' expr ')' STORED
  521            | column_atts AS '(' expr ')' VIRTUAL
  522            | column_atts AS '(' expr ')'

  523 opt_length: /* empty */
  524           | '(' INTNUM ')'
  525           | '(' INTNUM ',' INTNUM ')'

  526 opt_binary: /* empty */
  527           | BINARY

  528 opt_uz: /* empty */
  529       | opt_uz UNSIGNED
  530       | opt_uz ZEROFILL

  531 opt_csc: /* empty */
  532        | opt_csc CHAR SET STRING
  533        | opt_csc COLLATE STRING

  534 data_type: BIT opt_length
  535          | TINYINT opt_length opt_uz
  536          | SMALLINT opt_length opt_uz
  537          | MEDIUMINT opt_length opt_uz
  538          | INT opt_length opt_uz
  539          | INTEGER opt_length opt_uz
  540          | BIGINT opt_length opt_uz
  541          | REAL opt_length opt_uz
  542          | DOUBLE opt_length opt_uz
  543          | FLOAT opt_length opt_uz
  544          | DECIMAL opt_length opt_uz
  545          | DATE
  546          | TIME
  547          | TIMESTAMP
  548          | DATETIME
  549          | YEAR
  550          | CHAR opt_length opt_csc
  551          | VARCHAR '(' INTNUM ')' opt_csc
  552          | BINARY opt_length
  553          | VARBINARY '(' INTNUM ')'
  554          | TINYBLOB
  555          | BLOB
  556          | MEDIUMBLOB
  557          | LONGBLOB
  558          | TINYTEXT opt_binary opt_csc
  559          | TEXT opt_binary opt_csc
  560          | MEDIUMTEXT opt_binary opt_csc
  561          | LONGTEXT opt_binary opt_csc
  562          | ENUM '(' enum_list ')' opt_csc
  563          | SET '(' enum_list ')' opt_csc
  564          | BOOLEAN
  565          | UUID

  566 enum_list: STRING
  567          | enum_list ',' STRING

  568 create_select_statement: opt_ignore_replace opt_as select_stmt

  569 opt_ignore_replace: /* empty */
  570                   | IGNORE
  571                   | REPLACE

  572 stmt: set_stmt

  573 set_stmt: SET SCHEMA NAME
  574         | SET SCHEMA DEFAULT
  575         | SET set_list

  576 set_list: set_expr
  577         | set_list ',' set_expr

  578 set_expr: USERVAR COMPARISON expr
  579         | USERVAR ASSIGN expr


