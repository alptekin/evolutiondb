state 1

  376 alter_table_stmt: ALTER . TABLE NAME ADD CONSTRAINT NAME CHECK '(' expr ')'
  377                 | ALTER . TABLE NAME ADD CONSTRAINT NAME UNIQUE '(' unique_column_list ')'
  378                 | ALTER . TABLE NAME ADD CONSTRAINT NAME FOREIGN KEY '(' fk_column_list ')' REFERENCES NAME '(' fk_ref_column_list ')' fk_actions
  379                 | ALTER . TABLE NAME ADD CONSTRAINT NAME CHECK '(' expr ')' NOT VALIDATE
  380                 | ALTER . TABLE NAME ADD CONSTRAINT NAME FOREIGN KEY '(' fk_column_list ')' REFERENCES NAME '(' fk_ref_column_list ')' fk_actions NOT VALIDATE
  381                 | ALTER . TABLE NAME ADD CONSTRAINT NAME PRIMARY KEY '(' pk_column_list ')'
  382                 | ALTER . TABLE NAME DROP CONSTRAINT NAME
  383                 | ALTER . TABLE NAME RENAME CONSTRAINT NAME TO NAME
  384                 | ALTER . TABLE NAME ENABLE CONSTRAINT NAME
  385                 | ALTER . TABLE NAME DISABLE CONSTRAINT NAME
  386                 | ALTER . TABLE NAME VALIDATE CONSTRAINT NAME
  387                 | ALTER . TABLE NAME ADD COLUMN NAME data_type column_atts opt_col_position
  388                 | ALTER . TABLE NAME DROP COLUMN NAME
  389                 | ALTER . TABLE NAME DROP NAME
  390                 | ALTER . TABLE NAME RENAME COLUMN NAME TO NAME
  391                 | ALTER . TABLE NAME RENAME NAME TO NAME
  392                 | ALTER . TABLE NAME MODIFY COLUMN NAME data_type column_atts opt_col_position
  393                 | ALTER . TABLE NAME MODIFY NAME data_type column_atts opt_col_position
  394                 | ALTER . TABLE NAME CHANGE COLUMN NAME NAME data_type column_atts opt_col_position
  395                 | ALTER . TABLE NAME CHANGE NAME NAME data_type column_atts opt_col_position
  829 stmt: ALTER . TRIGGER NAME ENABLE
  830     | ALTER . TRIGGER NAME DISABLE
  846     | ALTER . SEQUENCE NAME seq_options
  847     | ALTER . SEQUENCE NAME RESTART
  848     | ALTER . SEQUENCE NAME RESTART WITH INTNUM
  849     | ALTER . SEQUENCE NAME RENAME TO NAME

    TRIGGER   shift, and go to state 44
    TABLE     shift, and go to state 45
    SEQUENCE  shift, and go to state 46


state 2

  373 analyze_table_stmt: ANALYZE . TABLE NAME
  374                   | ANALYZE . TABLE NAME '.' NAME

    TABLE  shift, and go to state 47


state 3

  808 call_stmt: CALL . NAME '(' ')'
  809          | CALL . NAME '(' call_arg_list ')'

