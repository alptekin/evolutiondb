  511                  | CREATE opt_temporary TABLE opt_if_not_exists NAME create_select_statement
  512                  | CREATE opt_temporary TABLE opt_if_not_exists NAME '.' NAME '(' create_col_list ')' create_select_statement
  513                  | CREATE opt_temporary TABLE opt_if_not_exists NAME '.' NAME create_select_statement

  514 opt_temporary: /* empty */
  515              | TEMPORARY
  516              | GLOBAL TEMPORARY

  517 create_col_list: create_definition
  518                | create_col_list ',' create_definition

  519 create_definition: PRIMARY KEY '(' pk_column_list ')'
  520                  | CONSTRAINT NAME PRIMARY KEY '(' pk_column_list ')'
  521                  | KEY '(' column_list ')'
  522                  | INDEX '(' column_list ')'
  523                  | FULLTEXT INDEX '(' column_list ')'
  524                  | FULLTEXT KEY '(' column_list ')'
  525                  | CHECK '(' expr ')'
  526                  | CONSTRAINT NAME CHECK '(' expr ')'
  527                  | FOREIGN KEY '(' fk_column_list ')' REFERENCES NAME '(' fk_ref_column_list ')' fk_actions
  528                  | FOREIGN KEY '(' fk_column_list ')' REFERENCES NAME '.' NAME '(' fk_ref_column_list ')' fk_actions
  529                  | CONSTRAINT NAME FOREIGN KEY '(' fk_column_list ')' REFERENCES NAME '(' fk_ref_column_list ')' fk_actions
  530                  | CONSTRAINT NAME FOREIGN KEY '(' fk_column_list ')' REFERENCES NAME '.' NAME '(' fk_ref_column_list ')' fk_actions
  531                  | UNIQUE '(' unique_column_list ')'
  532                  | CONSTRAINT NAME UNIQUE '(' unique_column_list ')'

  533 pk_column_list: NAME
  534               | pk_column_list ',' NAME

  535 fk_column_list: NAME
  536               | fk_column_list ',' NAME

  537 fk_ref_column_list: NAME
  538                   | fk_ref_column_list ',' NAME

  539 fk_actions: /* empty */
  540           | fk_actions ON DELETE CASCADE
  541           | fk_actions ON DELETE SET NULLX
  542           | fk_actions ON DELETE RESTRICT
  543           | fk_actions ON DELETE SET DEFAULT
  544           | fk_actions ON UPDATE CASCADE
  545           | fk_actions ON UPDATE SET NULLX
  546           | fk_actions ON UPDATE RESTRICT
  547           | fk_actions ON UPDATE SET DEFAULT
  548           | fk_actions ON DELETE NO_ACTION
  549           | fk_actions ON UPDATE NO_ACTION
  550           | fk_actions MATCH FULL
  551           | fk_actions MATCH SIMPLE
  552           | fk_actions MATCH PARTIAL
  553           | fk_actions DEFERRABLE
  554           | fk_actions NOT DEFERRABLE
  555           | fk_actions DEFERRABLE INITIALLY DEFERRED
  556           | fk_actions DEFERRABLE INITIALLY IMMEDIATE

  557 unique_column_list: NAME
  558                   | unique_column_list ',' NAME

  559 @34: /* empty */

  560 create_definition: @34 NAME data_type column_atts

  561 column_atts: /* empty */
  562            | column_atts NOT NULLX
  563            | column_atts NULLX
  564            | column_atts DEFAULT STRING
  565            | column_atts DEFAULT INTNUM
  566            | column_atts DEFAULT APPROXNUM
  567            | column_atts DEFAULT BOOL
  568            | column_atts DEFAULT FGEN_RANDOM_UUID '(' ')'
  569            | column_atts DEFAULT FGEN_RANDOM_UUID_V7 '(' ')'
  570            | column_atts DEFAULT FSNOWFLAKE_ID '(' ')'
  571            | column_atts DEFAULT CURRENT_TIMESTAMP
  572            | column_atts DEFAULT '(' expr ')'
  573            | column_atts AUTO_INCREMENT
  574            | column_atts AUTO_INCREMENT '(' INTNUM ',' INTNUM ')'
  575            | column_atts AUTO_INCREMENT '(' INTNUM ')'
  576            | column_atts IDENTITY '(' INTNUM ',' INTNUM ')'
  577            | column_atts IDENTITY '(' INTNUM ')'
  578            | column_atts IDENTITY
  579            | column_atts UNIQUE KEY
  580            | column_atts UNIQUE
  581            | column_atts PRIMARY KEY
  582            | column_atts KEY
  583            | column_atts COMMENT STRING
  584            | column_atts CHECK '(' expr ')'
  585            | column_atts CONSTRAINT NAME UNIQUE
  586            | column_atts CONSTRAINT NAME PRIMARY KEY
  587            | column_atts CONSTRAINT NAME CHECK '(' expr ')'
  588            | column_atts GENERATED ALWAYS AS '(' expr ')' STORED
  589            | column_atts GENERATED ALWAYS AS '(' expr ')' VIRTUAL
  590            | column_atts GENERATED ALWAYS AS '(' expr ')'
  591            | column_atts AS '(' expr ')' STORED
  592            | column_atts AS '(' expr ')' VIRTUAL
  593            | column_atts AS '(' expr ')'

  594 opt_length: /* empty */
  595           | '(' INTNUM ')'
  596           | '(' INTNUM ',' INTNUM ')'

  597 opt_binary: /* empty */
  598           | BINARY

  599 opt_uz: /* empty */
  600       | opt_uz UNSIGNED
  601       | opt_uz ZEROFILL

  602 opt_csc: /* empty */
  603        | opt_csc CHAR SET STRING
  604        | opt_csc COLLATE STRING

  605 data_type: BIT opt_length
  606          | TINYINT opt_length opt_uz
  607          | SMALLINT opt_length opt_uz
  608          | MEDIUMINT opt_length opt_uz
  609          | INT opt_length opt_uz
  610          | INTEGER opt_length opt_uz
  611          | BIGINT opt_length opt_uz
  612          | REAL opt_length opt_uz
  613          | DOUBLE opt_length opt_uz
  614          | FLOAT opt_length opt_uz
  615          | DECIMAL opt_length opt_uz
  616          | DATE
  617          | TIME
  618          | TIMESTAMP
  619          | DATETIME
  620          | YEAR
  621          | CHAR opt_length opt_csc
  622          | VARCHAR '(' INTNUM ')' opt_csc
  623          | BINARY opt_length
  624          | VARBINARY '(' INTNUM ')'
  625          | TINYBLOB
  626          | BLOB
  627          | MEDIUMBLOB
  628          | LONGBLOB
  629          | TINYTEXT opt_binary opt_csc
  630          | TEXT opt_binary opt_csc
  631          | MEDIUMTEXT opt_binary opt_csc
  632          | LONGTEXT opt_binary opt_csc
  633          | ENUM '(' enum_list ')' opt_csc
  634          | SET '(' enum_list ')' opt_csc
  635          | BOOLEAN
  636          | UUID
  637          | JSON

  638 enum_list: STRING
  639          | enum_list ',' STRING

  640 create_select_statement: opt_ignore_replace opt_as select_stmt

  641 opt_ignore_replace: /* empty */
  642                   | IGNORE
  643                   | REPLACE

  644 stmt: set_stmt

  645 set_stmt: SET SCHEMA NAME
  646         | SET SCHEMA DEFAULT
  647         | SET set_list

  648 set_list: set_expr
  649         | set_list ',' set_expr

  650 set_expr: USERVAR COMPARISON expr
  651         | USERVAR ASSIGN expr

  652 stmt: create_procedure_stmt

  653 create_procedure_stmt: CREATE PROCEDURE NAME '(' opt_proc_params ')' AS BEGINWORK proc_body_skip END
  654                      | CREATE PROCEDURE NAME '(' opt_proc_params ')' BEGINWORK proc_body_skip END
  655                      | CREATE OR REPLACE PROCEDURE NAME '(' opt_proc_params ')' AS BEGINWORK proc_body_skip END
  656                      | CREATE OR REPLACE PROCEDURE NAME '(' opt_proc_params ')' BEGINWORK proc_body_skip END
  657                      | CREATE FUNCTION NAME '(' opt_proc_params ')' RETURNS proc_return_type AS BEGINWORK proc_body_skip END
  658                      | CREATE FUNCTION NAME '(' opt_proc_params ')' RETURNS proc_return_type BEGINWORK proc_body_skip END
  659                      | CREATE OR REPLACE FUNCTION NAME '(' opt_proc_params ')' RETURNS proc_return_type AS BEGINWORK proc_body_skip END
  660                      | CREATE OR REPLACE FUNCTION NAME '(' opt_proc_params ')' RETURNS proc_return_type BEGINWORK proc_body_skip END

  661 opt_proc_params: /* empty */
  662                | proc_param_list

  663 proc_param_list: proc_param
  664                | proc_param_list ',' proc_param

  665 proc_param: NAME data_type
  666           | IN NAME data_type
  667           | OUT NAME data_type
  668           | INOUT NAME data_type

  669 proc_return_type: INTEGER
  670                 | INT
  671                 | VARCHAR
  672                 | TEXT
  673                 | BOOLEAN
  674                 | FLOAT
  675                 | DOUBLE
  676                 | BIGINT
  677                 | DATE
  678                 | TIMESTAMP

  679 proc_body_skip: /* empty */
  680               | proc_body_skip proc_body_any
  681               | proc_body_skip BEGINWORK proc_body_skip END
  682               | proc_body_skip IF proc_body_skip END IF
  683               | proc_body_skip WHILE proc_body_skip END WHILE
  684               | proc_body_skip LOOP proc_body_skip END LOOP
  685               | proc_body_skip FOREACH proc_body_skip END FOREACH
  686               | proc_body_skip CASE proc_body_skip END CASE

