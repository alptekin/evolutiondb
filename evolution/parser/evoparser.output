state 1

  529 alter_table_stmt: ALTER . TABLE NAME ADD CONSTRAINT NAME CHECK '(' expr ')'
  530                 | ALTER . TABLE NAME ADD CONSTRAINT NAME UNIQUE '(' unique_column_list ')'
  531                 | ALTER . TABLE NAME ADD CONSTRAINT NAME FOREIGN KEY '(' fk_column_list ')' REFERENCES NAME '(' fk_ref_column_list ')' fk_actions
  532                 | ALTER . TABLE NAME ADD CONSTRAINT NAME CHECK '(' expr ')' NOT VALIDATE
  533                 | ALTER . TABLE NAME ADD CONSTRAINT NAME FOREIGN KEY '(' fk_column_list ')' REFERENCES NAME '(' fk_ref_column_list ')' fk_actions NOT VALIDATE
  534                 | ALTER . TABLE NAME ADD CONSTRAINT NAME PRIMARY KEY '(' pk_column_list ')'
  535                 | ALTER . TABLE NAME DROP CONSTRAINT NAME
  536                 | ALTER . TABLE NAME RENAME CONSTRAINT NAME TO NAME
  537                 | ALTER . TABLE NAME ENABLE CONSTRAINT NAME
  538                 | ALTER . TABLE NAME DISABLE CONSTRAINT NAME
  539                 | ALTER . TABLE NAME VALIDATE CONSTRAINT NAME
  540                 | ALTER . TABLE NAME ADD COLUMN NAME data_type column_atts opt_col_position
  541                 | ALTER . TABLE NAME DROP COLUMN NAME
  542                 | ALTER . TABLE NAME DROP NAME
  543                 | ALTER . TABLE NAME RENAME COLUMN NAME TO NAME
  544                 | ALTER . TABLE NAME RENAME NAME TO NAME
  545                 | ALTER . TABLE NAME MODIFY COLUMN NAME data_type column_atts opt_col_position
  546                 | ALTER . TABLE NAME MODIFY NAME data_type column_atts opt_col_position
  547                 | ALTER . TABLE NAME CHANGE COLUMN NAME NAME data_type column_atts opt_col_position
  548                 | ALTER . TABLE NAME CHANGE NAME NAME data_type column_atts opt_col_position
  549                 | ALTER . TABLE NAME ENABLE ROW NAME SECURITY
  550                 | ALTER . TABLE NAME DISABLE ROW NAME SECURITY
  551                 | ALTER . MEMORY STORE NAME ENABLE ROW NAME SECURITY
  552                 | ALTER . MEMORY STORE NAME DISABLE ROW NAME SECURITY
  1003 stmt: ALTER . TRIGGER NAME ENABLE
  1004     | ALTER . TRIGGER NAME DISABLE
  1020     | ALTER . SEQUENCE NAME seq_options
  1021     | ALTER . SEQUENCE NAME RESTART
  1022     | ALTER . SEQUENCE NAME RESTART WITH INTNUM
  1023     | ALTER . SEQUENCE NAME RENAME TO NAME

    TRIGGER   shift, and go to state 73
    TABLE     shift, and go to state 74
    SEQUENCE  shift, and go to state 75
    MEMORY    shift, and go to state 76


state 2

  498 analyze_table_prefix: ANALYZE . TABLE

    TABLE  shift, and go to state 77


state 3

  980 call_stmt: CALL . NAME '(' ')'
  981          | CALL . NAME '(' call_arg_list ')'

    NAME  shift, and go to state 78


state 4

  379 create_index_stmt: CREATE . INDEX NAME ON NAME '(' index_col_list ')'
  380                  | CREATE . FULLTEXT INDEX NAME ON NAME '(' index_col_list ')'
  381                  | CREATE . INDEX IF EXISTS NAME ON NAME '(' index_col_list ')'
  382                  | CREATE . UNIQUE INDEX NAME ON NAME '(' index_col_list ')'
  383                  | CREATE . UNIQUE INDEX IF EXISTS NAME ON NAME '(' index_col_list ')'
  384                  | CREATE . INDEX NAME ON NAME USING HASH '(' index_col_list ')'
  385                  | CREATE . INDEX IF EXISTS NAME ON NAME USING HASH '(' index_col_list ')'
  386                  | CREATE . UNIQUE INDEX NAME ON NAME USING HASH '(' index_col_list ')'
  387                  | CREATE . UNIQUE INDEX IF EXISTS NAME ON NAME USING HASH '(' index_col_list ')'
  388                  | CREATE . INDEX CONCURRENTLY NAME ON NAME '(' index_col_list ')'
  389                  | CREATE . INDEX CONCURRENTLY IF EXISTS NAME ON NAME '(' index_col_list ')'
  390                  | CREATE . UNIQUE INDEX CONCURRENTLY NAME ON NAME '(' index_col_list ')'
  391                  | CREATE . UNIQUE INDEX CONCURRENTLY IF EXISTS NAME ON NAME '(' index_col_list ')'
  392                  | CREATE . INDEX CONCURRENTLY NAME ON NAME USING HASH '(' index_col_list ')'
  393                  | CREATE . UNIQUE INDEX CONCURRENTLY NAME ON NAME USING HASH '(' index_col_list ')'
  394                  | CREATE . INDEX NAME ON NAME USING HNSW '(' NAME opt_hnsw_opclass ')' opt_hnsw_with
  395                  | CREATE . INDEX IF EXISTS NAME ON NAME USING HNSW '(' NAME opt_hnsw_opclass ')' opt_hnsw_with
  427 create_checkpoint_store_stmt: CREATE . CHECKPOINT STORE NAME opt_ck_with
  428                             | CREATE . CHECKPOINT STORE IF EXISTS NAME opt_ck_with
  452 create_memory_store_stmt: CREATE . MEMORY STORE NAME mem_reset opt_mem_with
  453                         | CREATE . MEMORY STORE IF EXISTS NAME mem_reset opt_mem_with
  484 create_subscription_stmt: CREATE . SUBSCRIPTION NAME FOR CHANNEL NAME
  485                         | CREATE . SUBSCRIPTION IF EXISTS NAME FOR CHANNEL NAME
  508 create_policy_stmt: CREATE . POLICY NAME ON NAME opt_policy_as opt_policy_for opt_policy_to opt_policy_using opt_policy_check
  509                   | CREATE . POLICY NAME ON MEMORY STORE NAME opt_policy_as opt_policy_for opt_policy_to opt_policy_using opt_policy_check
  636 create_database_stmt: CREATE . DATABASE opt_if_not_exists NAME
  637                     | CREATE . SCHEMA opt_if_not_exists NAME
  645 create_domain_stmt: CREATE . DOMAIN NAME AS data_type
  646                   | CREATE . DOMAIN NAME AS data_type DEFAULT expr
  647                   | CREATE . DOMAIN NAME AS data_type NOT NULLX
  648                   | CREATE . DOMAIN NAME AS data_type CHECK '(' expr ')'
  649                   | CREATE . DOMAIN NAME AS data_type NOT NULLX CHECK '(' expr ')'
  654 create_table_stmt: CREATE . opt_temporary TABLE opt_if_not_exists NAME '(' create_col_list ')' opt_table_options opt_inherits
  657                  | CREATE . opt_temporary TABLE opt_if_not_exists NAME '.' NAME '(' create_col_list ')' opt_table_options
  658                  | CREATE . opt_temporary TABLE opt_if_not_exists NAME PARTITION OF NAME FOR VALUES FROM '(' INTNUM ')' TO '(' INTNUM ')'
  672                  | CREATE . opt_temporary TABLE opt_if_not_exists NAME '(' create_col_list ')' create_select_statement
  673                  | CREATE . opt_temporary TABLE opt_if_not_exists NAME create_select_statement
  674                  | CREATE . opt_temporary TABLE opt_if_not_exists NAME '.' NAME '(' create_col_list ')' create_select_statement
  675                  | CREATE . opt_temporary TABLE opt_if_not_exists NAME '.' NAME create_select_statement
  817 create_procedure_stmt: CREATE . PROCEDURE NAME '(' opt_proc_params ')' AS BEGINWORK proc_body_skip END
  818                      | CREATE . PROCEDURE NAME '(' opt_proc_params ')' BEGINWORK proc_body_skip END
  819                      | CREATE . OR REPLACE PROCEDURE NAME '(' opt_proc_params ')' AS BEGINWORK proc_body_skip END
