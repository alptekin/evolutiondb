  830     | ALTER TRIGGER NAME DISABLE
  831     | create_sequence_stmt

  832 create_sequence_stmt: CREATE SEQUENCE opt_if_not_exists NAME seq_options

  833 seq_options: /* empty */
  834            | seq_options seq_option

  835 seq_option: START WITH INTNUM
