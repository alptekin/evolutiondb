  879     | ALTER SEQUENCE NAME RENAME TO NAME

  880 opt_returning: /* empty */
  881              | RETURNING '*'
  882              | RETURNING returning_col_list

  883 returning_col_list: NAME
  884                   | returning_col_list ',' NAME


