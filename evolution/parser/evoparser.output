  516 create_table_stmt: CREATE opt_temporary TABLE opt_if_not_exists NAME '(' create_col_list ')' opt_table_options
  517                  | CREATE opt_temporary TABLE opt_if_not_exists NAME '.' NAME '(' create_col_list ')' opt_table_options
  518                  | CREATE opt_temporary TABLE opt_if_not_exists NAME PARTITION OF NAME FOR VALUES FROM '(' INTNUM ')' TO '(' INTNUM ')'

  519 opt_table_options: /* empty */
  520                  | opt_table_options AUTO_INCREMENT COMPARISON INTNUM
  521                  | opt_table_options AUTO_INCREMENT INTNUM
  522                  | opt_table_options ON NAME DELETE NAME
  523                  | opt_table_options ON NAME PRESERVE NAME
  524                  | opt_table_options SHARD BY HASH '(' NAME ')' SHARDS INTNUM
  525                  | opt_table_options SHARD BY RANGE '(' NAME ')' '(' shard_range_list ')'
  526                  | opt_table_options PARTITION BY RANGE '(' NAME ')'

  527 shard_range_list: shard_range_def
  528                 | shard_range_list ',' shard_range_def

  529 shard_range_def: SHARD NAME VALUES LESS THAN STRING ON NODE INTNUM
  530                | SHARD NAME VALUES LESS THAN MAXVALUE ON NODE INTNUM

  531 create_table_stmt: CREATE opt_temporary TABLE opt_if_not_exists NAME '(' create_col_list ')' create_select_statement
  532                  | CREATE opt_temporary TABLE opt_if_not_exists NAME create_select_statement
  533                  | CREATE opt_temporary TABLE opt_if_not_exists NAME '.' NAME '(' create_col_list ')' create_select_statement
  534                  | CREATE opt_temporary TABLE opt_if_not_exists NAME '.' NAME create_select_statement

  535 opt_temporary: /* empty */
  536              | TEMPORARY
  537              | GLOBAL TEMPORARY

  538 create_col_list: create_definition
  539                | create_col_list ',' create_definition

  540 create_definition: PRIMARY KEY '(' pk_column_list ')'
  541                  | CONSTRAINT NAME PRIMARY KEY '(' pk_column_list ')'
  542                  | KEY '(' column_list ')'
  543                  | INDEX '(' column_list ')'
  544                  | FULLTEXT INDEX '(' column_list ')'
  545                  | FULLTEXT KEY '(' column_list ')'
  546                  | CHECK '(' expr ')'
  547                  | CONSTRAINT NAME CHECK '(' expr ')'
  548                  | FOREIGN KEY '(' fk_column_list ')' REFERENCES NAME '(' fk_ref_column_list ')' fk_actions
  549                  | FOREIGN KEY '(' fk_column_list ')' REFERENCES NAME '.' NAME '(' fk_ref_column_list ')' fk_actions
  550                  | CONSTRAINT NAME FOREIGN KEY '(' fk_column_list ')' REFERENCES NAME '(' fk_ref_column_list ')' fk_actions
  551                  | CONSTRAINT NAME FOREIGN KEY '(' fk_column_list ')' REFERENCES NAME '.' NAME '(' fk_ref_column_list ')' fk_actions
  552                  | UNIQUE '(' unique_column_list ')'
  553                  | CONSTRAINT NAME UNIQUE '(' unique_column_list ')'

  554 pk_column_list: NAME
  555               | pk_column_list ',' NAME

  556 fk_column_list: NAME
  557               | fk_column_list ',' NAME

  558 fk_ref_column_list: NAME
  559                   | fk_ref_column_list ',' NAME

  560 fk_actions: /* empty */
  561           | fk_actions ON DELETE CASCADE
  562           | fk_actions ON DELETE SET NULLX
  563           | fk_actions ON DELETE RESTRICT
  564           | fk_actions ON DELETE SET DEFAULT
  565           | fk_actions ON UPDATE CASCADE
  566           | fk_actions ON UPDATE SET NULLX
  567           | fk_actions ON UPDATE RESTRICT
  568           | fk_actions ON UPDATE SET DEFAULT
  569           | fk_actions ON DELETE NO_ACTION
  570           | fk_actions ON UPDATE NO_ACTION
  571           | fk_actions MATCH FULL
  572           | fk_actions MATCH SIMPLE
  573           | fk_actions MATCH PARTIAL
  574           | fk_actions DEFERRABLE
  575           | fk_actions NOT DEFERRABLE
  576           | fk_actions DEFERRABLE INITIALLY DEFERRED
  577           | fk_actions DEFERRABLE INITIALLY IMMEDIATE

  578 unique_column_list: NAME
  579                   | unique_column_list ',' NAME

  580 @36: /* empty */

  581 create_definition: @36 NAME data_type column_atts

  582 column_atts: /* empty */
  583            | column_atts NOT NULLX
  584            | column_atts NULLX
  585            | column_atts DEFAULT STRING
  586            | column_atts DEFAULT INTNUM
  587            | column_atts DEFAULT APPROXNUM
  588            | column_atts DEFAULT BOOL
  589            | column_atts DEFAULT FGEN_RANDOM_UUID '(' ')'
  590            | column_atts DEFAULT FGEN_RANDOM_UUID_V7 '(' ')'
  591            | column_atts DEFAULT FSNOWFLAKE_ID '(' ')'
  592            | column_atts DEFAULT CURRENT_TIMESTAMP
  593            | column_atts DEFAULT '(' expr ')'
  594            | column_atts AUTO_INCREMENT
  595            | column_atts AUTO_INCREMENT '(' INTNUM ',' INTNUM ')'
  596            | column_atts AUTO_INCREMENT '(' INTNUM ')'
  597            | column_atts IDENTITY '(' INTNUM ',' INTNUM ')'
  598            | column_atts IDENTITY '(' INTNUM ')'
  599            | column_atts IDENTITY
  600            | column_atts UNIQUE KEY
  601            | column_atts UNIQUE
  602            | column_atts PRIMARY KEY
  603            | column_atts KEY
  604            | column_atts COMMENT STRING
  605            | column_atts CHECK '(' expr ')'
  606            | column_atts CONSTRAINT NAME UNIQUE
  607            | column_atts CONSTRAINT NAME PRIMARY KEY
  608            | column_atts CONSTRAINT NAME CHECK '(' expr ')'
  609            | column_atts GENERATED ALWAYS AS '(' expr ')' STORED
  610            | column_atts GENERATED ALWAYS AS '(' expr ')' VIRTUAL
  611            | column_atts GENERATED ALWAYS AS '(' expr ')'
  612            | column_atts AS '(' expr ')' STORED
  613            | column_atts AS '(' expr ')' VIRTUAL
  614            | column_atts AS '(' expr ')'

  615 opt_length: /* empty */
  616           | '(' INTNUM ')'
  617           | '(' INTNUM ',' INTNUM ')'

  618 opt_binary: /* empty */
  619           | BINARY

  620 opt_uz: /* empty */
  621       | opt_uz UNSIGNED
  622       | opt_uz ZEROFILL

  623 opt_csc: /* empty */
  624        | opt_csc CHAR SET STRING
  625        | opt_csc COLLATE STRING

  626 data_type: BIT opt_length
  627          | TINYINT opt_length opt_uz
  628          | SMALLINT opt_length opt_uz
  629          | MEDIUMINT opt_length opt_uz
  630          | INT opt_length opt_uz
  631          | INTEGER opt_length opt_uz
  632          | BIGINT opt_length opt_uz
  633          | REAL opt_length opt_uz
  634          | DOUBLE opt_length opt_uz
  635          | FLOAT opt_length opt_uz
  636          | DECIMAL opt_length opt_uz
  637          | DATE
  638          | TIME
  639          | TIMESTAMP
  640          | DATETIME
  641          | YEAR
  642          | CHAR opt_length opt_csc
  643          | VARCHAR '(' INTNUM ')' opt_csc
  644          | BINARY opt_length
  645          | VARBINARY '(' INTNUM ')'
  646          | TINYBLOB
  647          | BLOB
  648          | MEDIUMBLOB
  649          | LONGBLOB
  650          | TINYTEXT opt_binary opt_csc
  651          | TEXT opt_binary opt_csc
  652          | MEDIUMTEXT opt_binary opt_csc
  653          | LONGTEXT opt_binary opt_csc
  654          | ENUM '(' enum_list ')' opt_csc
  655          | SET '(' enum_list ')' opt_csc
  656          | BOOLEAN
  657          | UUID
  658          | JSON
  659          | data_type '[' ']'

  660 enum_list: STRING
  661          | enum_list ',' STRING

  662 create_select_statement: opt_ignore_replace opt_as select_stmt

  663 opt_ignore_replace: /* empty */
  664                   | IGNORE
  665                   | REPLACE

  666 stmt: set_stmt

  667 set_stmt: SET SCHEMA NAME
  668         | SET SCHEMA DEFAULT
  669         | SET set_list

  670 set_list: set_expr
  671         | set_list ',' set_expr

  672 set_expr: USERVAR COMPARISON expr
  673         | USERVAR ASSIGN expr

  674 stmt: create_procedure_stmt

  675 create_procedure_stmt: CREATE PROCEDURE NAME '(' opt_proc_params ')' AS BEGINWORK proc_body_skip END
  676                      | CREATE PROCEDURE NAME '(' opt_proc_params ')' BEGINWORK proc_body_skip END
  677                      | CREATE OR REPLACE PROCEDURE NAME '(' opt_proc_params ')' AS BEGINWORK proc_body_skip END
  678                      | CREATE OR REPLACE PROCEDURE NAME '(' opt_proc_params ')' BEGINWORK proc_body_skip END
  679                      | CREATE FUNCTION NAME '(' opt_proc_params ')' RETURNS proc_return_type AS BEGINWORK proc_body_skip END
  680                      | CREATE FUNCTION NAME '(' opt_proc_params ')' RETURNS proc_return_type BEGINWORK proc_body_skip END
  681                      | CREATE OR REPLACE FUNCTION NAME '(' opt_proc_params ')' RETURNS proc_return_type AS BEGINWORK proc_body_skip END
  682                      | CREATE OR REPLACE FUNCTION NAME '(' opt_proc_params ')' RETURNS proc_return_type BEGINWORK proc_body_skip END

  683 opt_proc_params: /* empty */
  684                | proc_param_list

  685 proc_param_list: proc_param
  686                | proc_param_list ',' proc_param

  687 proc_param: NAME data_type
  688           | IN NAME data_type
  689           | OUT NAME data_type
  690           | INOUT NAME data_type

  691 proc_return_type: INTEGER
  692                 | INT
  693                 | VARCHAR
  694                 | TEXT
  695                 | BOOLEAN
  696                 | FLOAT
  697                 | DOUBLE
  698                 | BIGINT
  699                 | DATE
  700                 | TIMESTAMP

  701 proc_body_skip: /* empty */
  702               | proc_body_skip proc_body_any
  703               | proc_body_skip BEGINWORK proc_body_skip END
  704               | proc_body_skip IF proc_body_skip END IF
  705               | proc_body_skip WHILE proc_body_skip END WHILE
  706               | proc_body_skip LOOP proc_body_skip END LOOP
  707               | proc_body_skip FOREACH proc_body_skip END FOREACH
  708               | proc_body_skip CASE proc_body_skip END CASE

