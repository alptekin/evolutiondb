state 0

    0 $accept: . stmt_list $end

    ALTER     shift, and go to state 1
    ANALYZE   shift, and go to state 2
    CALL      shift, and go to state 3
    CREATE    shift, and go to state 4
    COPY      shift, and go to state 5
    DELETE    shift, and go to state 6
    DROP      shift, and go to state 7
    INSERT    shift, and go to state 8
    RECLAIM   shift, and go to state 9
    RENAME    shift, and go to state 10
    REPLACE   shift, and go to state 11
    SET       shift, and go to state 12
    SELECT    shift, and go to state 13
    TRUNCATE  shift, and go to state 14
    UPDATE    shift, and go to state 15
    USE       shift, and go to state 16

    stmt_list              go to state 17
    stmt                   go to state 18
    select_stmt            go to state 19
    delete_stmt            go to state 20
    drop_table_stmt        go to state 21
    create_index_stmt      go to state 22
    drop_index_stmt        go to state 23
    truncate_table_stmt    go to state 24
    reclaim_table_stmt     go to state 25
    analyze_table_stmt     go to state 26
    alter_table_stmt       go to state 27
    insert_stmt            go to state 28
    replace_stmt           go to state 29
    copy_stmt              go to state 30
    update_stmt            go to state 31
    create_database_stmt   go to state 32
    create_domain_stmt     go to state 33
    use_database_stmt      go to state 34
    create_table_stmt      go to state 35
    set_stmt               go to state 36
    create_procedure_stmt  go to state 37
