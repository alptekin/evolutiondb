  501            | column_atts DEFAULT FGEN_RANDOM_UUID '(' ')'
  502            | column_atts DEFAULT FGEN_RANDOM_UUID_V7 '(' ')'
  503            | column_atts DEFAULT FSNOWFLAKE_ID '(' ')'
  504            | column_atts DEFAULT CURRENT_TIMESTAMP
  505            | column_atts DEFAULT '(' expr ')'
  506            | column_atts AUTO_INCREMENT
  507            | column_atts AUTO_INCREMENT '(' INTNUM ',' INTNUM ')'
  508            | column_atts AUTO_INCREMENT '(' INTNUM ')'
  509            | column_atts IDENTITY '(' INTNUM ',' INTNUM ')'
  510            | column_atts IDENTITY '(' INTNUM ')'
  511            | column_atts IDENTITY
  512            | column_atts UNIQUE KEY
  513            | column_atts UNIQUE
  514            | column_atts PRIMARY KEY
  515            | column_atts KEY
  516            | column_atts COMMENT STRING
  517            | column_atts CHECK '(' expr ')'
  518            | column_atts CONSTRAINT NAME UNIQUE
  519            | column_atts CONSTRAINT NAME PRIMARY KEY
  520            | column_atts CONSTRAINT NAME CHECK '(' expr ')'
  521            | column_atts GENERATED ALWAYS AS '(' expr ')' STORED
  522            | column_atts GENERATED ALWAYS AS '(' expr ')' VIRTUAL
  523            | column_atts GENERATED ALWAYS AS '(' expr ')'
  524            | column_atts AS '(' expr ')' STORED
  525            | column_atts AS '(' expr ')' VIRTUAL
  526            | column_atts AS '(' expr ')'

  527 opt_length: /* empty */
  528           | '(' INTNUM ')'
  529           | '(' INTNUM ',' INTNUM ')'

  530 opt_binary: /* empty */
  531           | BINARY

  532 opt_uz: /* empty */
  533       | opt_uz UNSIGNED
  534       | opt_uz ZEROFILL

  535 opt_csc: /* empty */
  536        | opt_csc CHAR SET STRING
  537        | opt_csc COLLATE STRING

  538 data_type: BIT opt_length
  539          | TINYINT opt_length opt_uz
  540          | SMALLINT opt_length opt_uz
  541          | MEDIUMINT opt_length opt_uz
  542          | INT opt_length opt_uz
  543          | INTEGER opt_length opt_uz
  544          | BIGINT opt_length opt_uz
  545          | REAL opt_length opt_uz
  546          | DOUBLE opt_length opt_uz
  547          | FLOAT opt_length opt_uz
  548          | DECIMAL opt_length opt_uz
  549          | DATE
  550          | TIME
  551          | TIMESTAMP
  552          | DATETIME
  553          | YEAR
  554          | CHAR opt_length opt_csc
  555          | VARCHAR '(' INTNUM ')' opt_csc
  556          | BINARY opt_length
  557          | VARBINARY '(' INTNUM ')'
  558          | TINYBLOB
  559          | BLOB
  560          | MEDIUMBLOB
  561          | LONGBLOB
  562          | TINYTEXT opt_binary opt_csc
  563          | TEXT opt_binary opt_csc
  564          | MEDIUMTEXT opt_binary opt_csc
  565          | LONGTEXT opt_binary opt_csc
  566          | ENUM '(' enum_list ')' opt_csc
  567          | SET '(' enum_list ')' opt_csc
  568          | BOOLEAN
  569          | UUID

  570 enum_list: STRING
  571          | enum_list ',' STRING

  572 create_select_statement: opt_ignore_replace opt_as select_stmt

  573 opt_ignore_replace: /* empty */
  574                   | IGNORE
  575                   | REPLACE

  576 stmt: set_stmt

  577 set_stmt: SET SCHEMA NAME
  578         | SET SCHEMA DEFAULT
  579         | SET set_list

  580 set_list: set_expr
  581         | set_list ',' set_expr

  582 set_expr: USERVAR COMPARISON expr
  583         | USERVAR ASSIGN expr

  584 stmt: create_procedure_stmt

  585 create_procedure_stmt: CREATE PROCEDURE NAME '(' opt_proc_params ')' AS BEGINWORK proc_body_skip END
  586                      | CREATE PROCEDURE NAME '(' opt_proc_params ')' BEGINWORK proc_body_skip END
  587                      | CREATE OR REPLACE PROCEDURE NAME '(' opt_proc_params ')' AS BEGINWORK proc_body_skip END
  588                      | CREATE OR REPLACE PROCEDURE NAME '(' opt_proc_params ')' BEGINWORK proc_body_skip END
  589                      | CREATE FUNCTION NAME '(' opt_proc_params ')' RETURNS proc_return_type AS BEGINWORK proc_body_skip END
  590                      | CREATE FUNCTION NAME '(' opt_proc_params ')' RETURNS proc_return_type BEGINWORK proc_body_skip END
  591                      | CREATE OR REPLACE FUNCTION NAME '(' opt_proc_params ')' RETURNS proc_return_type AS BEGINWORK proc_body_skip END
  592                      | CREATE OR REPLACE FUNCTION NAME '(' opt_proc_params ')' RETURNS proc_return_type BEGINWORK proc_body_skip END

  593 opt_proc_params: /* empty */
  594                | proc_param_list

  595 proc_param_list: proc_param
  596                | proc_param_list ',' proc_param

  597 proc_param: NAME data_type
  598           | IN NAME data_type
  599           | OUT NAME data_type
  600           | INOUT NAME data_type

  601 proc_return_type: INTEGER
  602                 | INT
  603                 | VARCHAR
  604                 | TEXT
  605                 | BOOLEAN
  606                 | FLOAT
  607                 | DOUBLE
  608                 | BIGINT
  609                 | DATE
  610                 | TIMESTAMP

  611 proc_body_skip: /* empty */
  612               | proc_body_skip proc_body_any
  613               | proc_body_skip BEGINWORK proc_body_skip END
  614               | proc_body_skip IF proc_body_skip END IF
  615               | proc_body_skip WHILE proc_body_skip END WHILE
  616               | proc_body_skip LOOP proc_body_skip END LOOP
  617               | proc_body_skip FOREACH proc_body_skip END FOREACH
  618               | proc_body_skip CASE proc_body_skip END CASE

