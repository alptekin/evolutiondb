  500            | column_atts DEFAULT FSNOWFLAKE_ID '(' ')'
  501            | column_atts DEFAULT CURRENT_TIMESTAMP
  502            | column_atts DEFAULT '(' expr ')'
  503            | column_atts AUTO_INCREMENT
  504            | column_atts AUTO_INCREMENT '(' INTNUM ',' INTNUM ')'
  505            | column_atts AUTO_INCREMENT '(' INTNUM ')'
  506            | column_atts IDENTITY '(' INTNUM ',' INTNUM ')'
  507            | column_atts IDENTITY '(' INTNUM ')'
  508            | column_atts IDENTITY
  509            | column_atts UNIQUE KEY
  510            | column_atts UNIQUE
  511            | column_atts PRIMARY KEY
  512            | column_atts KEY
  513            | column_atts COMMENT STRING
  514            | column_atts CHECK '(' expr ')'
  515            | column_atts CONSTRAINT NAME UNIQUE
  516            | column_atts CONSTRAINT NAME PRIMARY KEY
  517            | column_atts CONSTRAINT NAME CHECK '(' expr ')'
  518            | column_atts GENERATED ALWAYS AS '(' expr ')' STORED
  519            | column_atts GENERATED ALWAYS AS '(' expr ')' VIRTUAL
  520            | column_atts GENERATED ALWAYS AS '(' expr ')'
  521            | column_atts AS '(' expr ')' STORED
  522            | column_atts AS '(' expr ')' VIRTUAL
  523            | column_atts AS '(' expr ')'

  524 opt_length: /* empty */
  525           | '(' INTNUM ')'
  526           | '(' INTNUM ',' INTNUM ')'

  527 opt_binary: /* empty */
  528           | BINARY

  529 opt_uz: /* empty */
  530       | opt_uz UNSIGNED
  531       | opt_uz ZEROFILL

  532 opt_csc: /* empty */
  533        | opt_csc CHAR SET STRING
  534        | opt_csc COLLATE STRING

  535 data_type: BIT opt_length
  536          | TINYINT opt_length opt_uz
  537          | SMALLINT opt_length opt_uz
  538          | MEDIUMINT opt_length opt_uz
  539          | INT opt_length opt_uz
  540          | INTEGER opt_length opt_uz
  541          | BIGINT opt_length opt_uz
  542          | REAL opt_length opt_uz
  543          | DOUBLE opt_length opt_uz
  544          | FLOAT opt_length opt_uz
  545          | DECIMAL opt_length opt_uz
  546          | DATE
  547          | TIME
  548          | TIMESTAMP
  549          | DATETIME
  550          | YEAR
  551          | CHAR opt_length opt_csc
  552          | VARCHAR '(' INTNUM ')' opt_csc
  553          | BINARY opt_length
  554          | VARBINARY '(' INTNUM ')'
  555          | TINYBLOB
  556          | BLOB
  557          | MEDIUMBLOB
  558          | LONGBLOB
  559          | TINYTEXT opt_binary opt_csc
  560          | TEXT opt_binary opt_csc
  561          | MEDIUMTEXT opt_binary opt_csc
  562          | LONGTEXT opt_binary opt_csc
  563          | ENUM '(' enum_list ')' opt_csc
  564          | SET '(' enum_list ')' opt_csc
  565          | BOOLEAN
  566          | UUID

  567 enum_list: STRING
  568          | enum_list ',' STRING

  569 create_select_statement: opt_ignore_replace opt_as select_stmt

  570 opt_ignore_replace: /* empty */
  571                   | IGNORE
  572                   | REPLACE

  573 stmt: set_stmt

  574 set_stmt: SET SCHEMA NAME
  575         | SET SCHEMA DEFAULT
  576         | SET set_list

  577 set_list: set_expr
  578         | set_list ',' set_expr

  579 set_expr: USERVAR COMPARISON expr
  580         | USERVAR ASSIGN expr


