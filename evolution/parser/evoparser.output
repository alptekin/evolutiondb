  807 stmt: call_stmt

  808 call_stmt: CALL NAME '(' ')'
  809          | CALL NAME '(' call_arg_list ')'

  810 call_arg_list: call_arg
  811              | call_arg_list ',' call_arg

  812 call_arg: INTNUM
  813         | STRING
  814         | APPROXNUM
  815         | NULLX
  816         | BOOL
  817         | NAME
  818         | USERVAR

  819 stmt: create_trigger_stmt

  820 create_trigger_stmt: CREATE TRIGGER NAME trigger_timing trigger_event ON NAME FOR EACH ROW BEGINWORK proc_body_skip END

  821 trigger_timing: BEFORE
  822               | AFTER

  823 trigger_event: INSERT
  824              | UPDATE
  825              | DELETE

  826 stmt: drop_trigger_stmt

  827 drop_trigger_stmt: DROP TRIGGER NAME
  828                  | DROP TRIGGER IF EXISTS NAME

