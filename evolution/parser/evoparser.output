  759 stmt: create_trigger_stmt

  760 create_trigger_stmt: CREATE TRIGGER NAME trigger_timing trigger_event ON NAME FOR EACH ROW BEGINWORK proc_body_skip END

  761 trigger_timing: BEFORE
  762               | AFTER

  763 trigger_event: INSERT
  764              | UPDATE
  765              | DELETE

  766 stmt: drop_trigger_stmt

  767 drop_trigger_stmt: DROP TRIGGER NAME
  768                  | DROP TRIGGER IF EXISTS NAME

  769 stmt: ALTER TRIGGER NAME ENABLE
  770     | ALTER TRIGGER NAME DISABLE

  771 opt_returning: /* empty */
  772              | RETURNING '*'
  773              | RETURNING returning_col_list

  774 returning_col_list: NAME
  775                   | returning_col_list ',' NAME


