# Copy to `.env` next to docker-compose.demo.yml to pick the LLM
# backend the agent uses.
#
# Priority inside make_llm():
#   1. OLLAMA_BASE_URL or OLLAMA_MODEL → OllamaLLM (local, CPU-friendly)
#   2. ANTHROPIC_API_KEY                → ClaudeLLM (cloud)
#   3. neither                          → StubLLM (deterministic, offline / CI)

# ----- Real Claude (cloud) -----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ----- Local Ollama LLM (compose profile: local-llm) -----
# Uncomment + run:
#   docker compose -f docker-compose.demo.yml --profile local-llm \
#       --env-file .env up --build --abort-on-container-exit
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
