# Microsoft Entra ID app registration (work / Microsoft 365 tenant).
# Create the app at https://portal.azure.com → Microsoft Entra ID →
# App registrations → New registration. Public client / native, redirect
# URI not required for device-code flow. Then under "API permissions"
# add delegated: Chat.Read, User.Read, offline_access — user can
# self-consent, no tenant admin approval needed.
# (Entra ID is the current name for what used to be Azure Active
# Directory; the portal links and APIs are unchanged.)
AZURE_TENANT_ID=common
AZURE_CLIENT_ID=

# Where to write memories. Defaults work for the bundled docker compose.
EVOSQL_HOST=127.0.0.1
EVOSQL_PORT=5433
EVOSQL_USER=admin
EVOSQL_PASSWORD=admin
EVOSQL_DATABASE=evosql

# Memory namespace — must match the MCP server's MCP_USER_ID so
# search_memory in Claude / ChatGPT sees the synced messages.
MCP_USER_ID=alptekin_topal

# Memory store name. The mcp-server-evosql defaults to mcp_mem; pointing
# Teams sync at the same store keeps everything queryable in one place.
# Change to teams_messages if you want a dedicated store (then add it
# to the MCP server's search scope).
TEAMS_MEMORY_STORE=mcp_mem

# Polling interval in seconds (used with --daemon).
TEAMS_POLL_INTERVAL=600

# Where MSAL caches the refresh token. Persists across runs so the
# device-code flow only happens once.
TEAMS_TOKEN_CACHE=~/.evosql/teams_token_cache.json
