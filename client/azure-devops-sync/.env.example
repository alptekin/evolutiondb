# Azure DevOps -> EvolutionDB memory sync
#
# Copy to .env (gitignored) and fill in. Real values never belong in the repo.

# --- Azure DevOps (required) -------------------------------------------
# Your organization url and a Personal Access Token with at least
# Code (Read) + Build (Read) scopes. "Me" is the PAT owner.
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/your-org
AZURE_DEVOPS_PAT=

# Optional comma-separated project filter; empty = every project in the org.
AZURE_DEVOPS_PROJECTS=

# --- EvolutionDB connection --------------------------------------------
EVOSQL_HOST=127.0.0.1
EVOSQL_PORT=5433
EVOSQL_USER=admin
EVOSQL_PASSWORD=admin
EVOSQL_DATABASE=evosql

# Namespace shared with the MCP server (its MCP_USER_ID).
MCP_USER_ID=default_user

# Memory store the records land in (the MCP server's primary store).
ADO_MEMORY_STORE=mcp_mem

# Daemon poll interval in seconds (the --interval flag wins when passed).
ADO_POLL_INTERVAL=900
