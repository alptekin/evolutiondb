# --- Slack ---------------------------------------------------------
# User OAuth token (xoxp-…). Create at
# https://api.slack.com/apps → your app → OAuth & Permissions
# Required user-token scopes:
#   channels:history    channels:read
#   groups:history      groups:read
#   im:history          im:read
#   mpim:history        mpim:read
#   users:read
# These are *user* scopes, not bot scopes — the package walks the
# conversations the human is actually part of.
SLACK_USER_TOKEN=xoxp-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- EvolutionDB ---------------------------------------------------
EVOSQL_HOST=127.0.0.1
EVOSQL_PORT=5433
EVOSQL_USER=admin
EVOSQL_PASSWORD=admin
EVOSQL_DATABASE=evosql

# --- MCP correlation -----------------------------------------------
MCP_USER_ID=default_user
SLACK_MEMORY_STORE=mcp_mem

# Daemon-mode poll interval, seconds.
SLACK_POLL_INTERVAL=600
