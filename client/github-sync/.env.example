# --- GitHub --------------------------------------------------------
# Personal Access Token. The classic flavour is fine; the only scopes
# we need are `repo` (private repos) or `public_repo` (public only)
# plus `read:user`. Generate at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The handle to follow. `involves:<user>` matches authored, mentioned,
# assigned, commented — i.e. every thread you have skin in.
GITHUB_USERNAME=your-handle

# --- EvolutionDB ---------------------------------------------------
EVOSQL_HOST=127.0.0.1
EVOSQL_PORT=5433
EVOSQL_USER=admin
EVOSQL_PASSWORD=admin
EVOSQL_DATABASE=evosql

# --- MCP correlation -----------------------------------------------
# Same namespace the MCP server uses so search_memory returns these
# rows alongside saved facts and Teams messages.
MCP_USER_ID=default_user

# Store these records under the existing MCP memory store. Set to
# `github_messages` if you want them in a separate bucket.
GITHUB_MEMORY_STORE=mcp_mem

# Daemon-mode poll interval, seconds. 900s = 15 min is plenty for
# human-paced GitHub activity.
GITHUB_POLL_INTERVAL=900
