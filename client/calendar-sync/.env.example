# --- Google OAuth -------------------------------------------------
# Same kind of credentials as gmail-sync. You can reuse a single
# OAuth Desktop client across both packages — just add the Calendar
# API to the same Google Cloud project before requesting consent.
#
# Quick path:
#   1. https://console.cloud.google.com/apis/library/calendar-json.googleapis.com
#      → Enable
#   2. APIs & Services → Credentials → reuse your existing Desktop
#      OAuth client (or create a new one — Application type "Desktop app")
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Refresh-token cache location. 0600 on POSIX. Keep this distinct
# from gmail-sync so revoking one scope does not break the other.
CALENDAR_TOKEN_CACHE=~/.evosql/calendar_token.json

# --- EvolutionDB --------------------------------------------------
EVOSQL_HOST=127.0.0.1
EVOSQL_PORT=5433
EVOSQL_USER=admin
EVOSQL_PASSWORD=admin
EVOSQL_DATABASE=evosql

# --- MCP correlation ----------------------------------------------
MCP_USER_ID=default_user
CALENDAR_MEMORY_STORE=mcp_mem

# Daemon-mode poll interval, seconds.
CALENDAR_POLL_INTERVAL=900
