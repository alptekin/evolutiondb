{
  "site": "docs",
  "title": "EvolutionDB",
  "comment": "docs.evolutiondb.org. Maps each page to the engine source it documents. When a page's sources change between two release tags, the generator asks the model to update that page. Paths are relative to the channel folder, for example ref/select means <channel>/ref/select/index.html.",
  "watch": [
    "src/backend/parser/evoparser.y",
    "src/backend/parser/evolexer.l",
    "src/backend/commands",
    "src/backend/executor",
    "src/include/version.h"
  ],
  "new_command_source": "src/backend/parser/evoparser.y",
  "pages": {
    "ref/select": ["src/backend/commands/Select.c", "src/backend/executor/expression.c"],
    "ref/insert": ["src/backend/commands/Insert.c"],
    "ref/replace": ["src/backend/commands/Insert.c"],
    "ref/update": ["src/backend/commands/Update.c"],
    "ref/delete": ["src/backend/commands/Delete.c"],
    "ref/copy": ["src/backend/commands/Copy.c", "src/backend/commands/csv.c"],
    "ref/truncate": ["src/backend/commands/Delete.c"],
    "ref/create-table": ["src/backend/commands/Create.c"],
    "ref/alter-table": ["src/backend/commands/Create.c"],
    "ref/drop-table": ["src/backend/commands/Drop.c"],
    "ref/create-index": ["src/backend/commands/Index.c"],
    "ref/drop-index": ["src/backend/commands/Index.c", "src/backend/commands/Drop.c"],
    "ref/create-database": ["src/backend/commands/DatabaseMgmt.c"],
    "ref/use": ["src/backend/commands/DatabaseMgmt.c"],
    "ref/create-sequence": ["src/backend/commands/Sequence.c"],
    "ref/create-trigger": ["src/backend/commands/Trigger.c"],
    "ref/create-procedure": ["src/backend/commands/Procedure.c"],
    "ref/call": ["src/backend/commands/Procedure.c"],
    "ref/create-policy": ["src/backend/commands/Policy.c"],
    "ref/grant": ["src/backend/commands/GrantMgmt.c"],
    "ref/revoke": ["src/backend/commands/GrantMgmt.c"],
    "ref/create-user": ["src/backend/commands/UserMgmt.c"],
    "ref/analyze": ["src/backend/commands/Analyze.c"],
    "ref/reclaim": ["src/backend/commands/Reclaim.c", "src/backend/commands/auto_reclaim.c"],
    "ref/checkpoint": ["src/backend/access/Checkpoint.c"],
    "ref/listen-notify": ["src/backend/commands/Notify.c"],
    "ref/create-memory-store": ["src/backend/commands/Memory.c"],
    "ref/memory-put": ["src/backend/commands/Memory.c"],
    "ref/memory-get": ["src/backend/commands/Memory.c"],
    "ref/memory-search": ["src/backend/commands/Memory.c", "src/backend/storage/hnsw.c"],
    "ref/memory-delete": ["src/backend/commands/Memory.c"],
    "ref/create-entity-store": ["src/backend/commands/Entity.c"],
    "ref/create-doc-store": ["src/backend/commands/Document.c"],
    "ref/create-graph-store": ["src/backend/commands/Graph.c"],
    "ref/create-message-log": ["src/backend/commands/MessageLog.c"],
    "ref/create-subscription": ["src/backend/commands/Subscription.c"],
    "ref/create-job": ["src/backend/commands/Schedule.c"],
    "sql/ddl": ["src/backend/commands/Create.c", "src/backend/commands/Drop.c"],
    "sql/dml": ["src/backend/commands/Insert.c", "src/backend/commands/Update.c", "src/backend/commands/Delete.c"],
    "sql/queries": ["src/backend/commands/Select.c"],
    "sql/datatypes": ["src/backend/access/tuple_format.c"],
    "sql/functions": ["src/backend/executor/expression.c"],
    "sql/indexes": ["src/backend/commands/Index.c", "src/backend/storage/btree2.c", "src/backend/storage/hash_idx.c", "src/backend/storage/hnsw.c"],
    "sql/mvcc": ["src/backend/access/mvcc.c"],
    "sql/fulltext": ["src/backend/commands/FullText.c"],
    "sql/json": ["src/backend/executor/Json.c"],
    "sql/vectors": ["src/backend/storage/hnsw.c"],
    "sql/memory": ["src/backend/commands/Memory.c", "src/backend/commands/Entity.c"],
    "sql/stores": ["src/backend/commands/Document.c", "src/backend/commands/Graph.c", "src/backend/commands/MessageLog.c"],
    "sql/notify": ["src/backend/commands/Notify.c"],
    "sql/subscriptions": ["src/backend/commands/Subscription.c"],
    "sql/jobs": ["src/backend/commands/Schedule.c"],
    "sql/rls": ["src/backend/commands/Policy.c"],
    "sql/triggers": ["src/backend/commands/Trigger.c", "src/backend/commands/Procedure.c"]
  }
}
