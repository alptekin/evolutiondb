# .env.example — template for the EvolutionDB stack.
#
# Copy to .env and fill in. The real .env is gitignored; NEVER commit it.
#   cp .env.example .env        # ./install.sh does this for you
#
# Everything here is read by docker-compose.yml (engine + agent) and by
# the agent / MCP / connector processes. Blank values fall back to the
# documented defaults.

# ---- Engine auth ---------------------------------------------------
# Admin username for the SQL engine.
EVOSQL_USER_NAME=admin
# Admin password. CHANGE THIS — leaving it blank/admin keeps the
# well-known default credential. ./install.sh generates a random one.
EVOSQL_PASSWORD=

# ---- Encryption at rest (optional) ---------------------------------
# Whole-DB TDE passphrase (AES-256-CTR page encryption). Generate your
# OWN (e.g. `openssl rand -hex 24`). Empty = the DB file and WAL are
# PLAINTEXT on disk. TDE only activates with a TLS=1 / EVO_ENCRYPTION
# build AND this passphrase set; Page 0 (FileHeader) is always plaintext.
EVOSQL_ENCRYPTION_KEY=

# ---- Network posture -----------------------------------------------
# Interface the engine binds inside the container. Default loopback
# (127.0.0.1) keeps it private. Set 0.0.0.0 ONLY together with TLS
# cert/key and EVOSQL_MCP_AUTH_TOKEN to expose it externally.
EVOSQL_BIND=127.0.0.1
# Host directory for the database volume (optional override; the compose
# named volume is used when blank).
EVOSQL_DATA_DIR=

# ---- LLM / agent ---------------------------------------------------
# Anthropic API key for the default Claude backend. Blank = the agent
# runs without a cloud model (no enrichment / no LLM turns).
ANTHROPIC_API_KEY=
# Model id the agent uses (blank = built-in default).
EVOSQL_AGENT_MODEL=
# Daily LLM token budget cap. 0 = off (no cap). 200000 is a sane default.
EVOSQL_LLM_DAILY_TOKENS=200000

# ---- PII egress ----------------------------------------------------
# Mask PII in outbound LLM prompts. off (default) = enrichment text goes
# to the model provider UNMASKED. on = masked before it leaves the host.
EVOSQL_PII_EGRESS=off

# ---- MCP HTTP transport --------------------------------------------
# Bearer token required by the MCP HTTP transport. Blank = the HTTP
# transport is unauthenticated; set a token before exposing it.
EVOSQL_MCP_AUTH_TOKEN=
# Memory namespace / sticky user id for save_memory / search_memory.
MCP_USER_ID=default_user
